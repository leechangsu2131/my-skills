# Discord 메모 에이전트 환경변수
# 이 파일을 .env 로 복사하고 값을 채우세요
# cp .env.example .env

# ──────────────────────────────
# [필수] Discord 봇 토큰
# 취득: https://discord.com/developers/applications
#   → 앱 선택 → Bot → Reset Token
# ──────────────────────────────
DISCORD_BOT_TOKEN=여기에_봇_토큰_입력

# ──────────────────────────────
# [자동설정] 채널 ID & 웹훅 (이미 설정됨)
# ──────────────────────────────
DISCORD_CHANNEL_ID=1477078755951378432
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/1477078821630120069/qXjZ4jhy0-BmNsS0udzWbwTR3zaX406OeGz_82qcm6YrVP0YefyqrTjtdhvSKKldhsh0

# ──────────────────────────────
# [선택] Claude API (일정 자동 추출 향상)
# 없으면 규칙 기반 분류로 동작
# 취득: https://console.anthropic.com
# ──────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────
# [선택] Google Calendar 연동
# GOOGLE_CREDENTIALS_FILE: 서비스 계정 JSON 경로
# ──────────────────────────────
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=primary

# ──────────────────────────────
# [선택] 폴링 간격 (초, 기본 300=5분)
# ──────────────────────────────
POLL_INTERVAL_SEC=300
