# 경주시립도서관 연동 스크립트 설정파일
# 이 파일을 복사하여 .env 로 저장 후 실제 값을 입력하세요 (절대 공유 금지!)

# 노션 통합(Integration) 시크릿 토큰 (https://www.notion.so/my-integrations 에서 발급)
NOTION_TOKEN=secret_여기에_실제_토큰_입력

# 도서신청 책 db 의 데이터베이스 ID
NOTION_DATABASE_ID=313ddde1e1df80e9b161e2c5888f80d6

# =====================================================
# 도서관 계정 (희망도서 신청용, request_books.py에서 사용)
# 1인 월 2권 제한이므로 여러 계정 등록 가능 (최대 10개)
# =====================================================
LIBRARY_ACCOUNT_1_ID=아이디1
LIBRARY_ACCOUNT_1_PW=비밀번호1
