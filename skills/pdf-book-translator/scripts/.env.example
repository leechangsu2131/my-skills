# ──────────────────────────────────────────
# PDF 챕터 번역기 환경변수
# 이 파일을 .env 로 복사 후 값을 채우세요
# cp .env.example .env
# ──────────────────────────────────────────

# [필수] 번역할 PDF 경로
PDF_PATH=C:\Users\YourName\Documents\book.pdf

# [필수] Gemini Gems URL (공유 링크)
GEMS_URL=https://gemini.google.com/gem/1tKZdgyxaR4D3mEaxol5JoXhy1i9r3Oz3

# [필수] Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_URL

# [선택] Discord 채널에 올릴 때 챕터 제목 앞에 붙일 이모지
CHAPTER_EMOJI=📖
