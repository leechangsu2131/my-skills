# 사회 학습 페이지 첫 화면 URL
SOCIAL_CLASS_BASE_URL=https://www.i-scream.co.kr/user/subject/SubjectChasiList.do#none

# `music-class-helper`와 같은 디버깅 포트를 쓰면 로그인 세션을 자연스럽게 공유할 수 있습니다.
SOCIAL_CLASS_REMOTE_PORT=9222

# 비워두면 music-class-helper가 기본으로 쓰는 프로필 경로를 그대로 재사용합니다.
SOCIAL_CLASS_CHROME_PROFILE_DIR=

# Chrome 실행 파일이 기본 경로에 없을 때만 지정하세요.
SOCIAL_CLASS_CHROME_PATH=

# 지도서 PDF를 기본으로 연결하고 싶을 때 지정하세요.
SOCIAL_CLASS_GUIDE_PDF=

# 지도서에서 몇 페이지를 잘라낼지 지정합니다.
SOCIAL_CLASS_GUIDE_EXTRACT_PAGES=4

# 차시 카드 안에서 눌러야 하는 자료 버튼 키워드입니다. 쉼표로 구분합니다.
SOCIAL_CLASS_RESOURCE_KEYWORDS=과정안,활동지,교과서PDF,공유자료실,자료

# 화면에 표시할 자료 이름입니다.
SOCIAL_CLASS_RESOURCE_LABEL=수업 자료

# 프로그램 화면 제목입니다.
SOCIAL_CLASS_LABEL=사회 수업 도우미

# 상태 저장 파일을 다른 위치로 두고 싶을 때만 지정하세요.
SOCIAL_CLASS_DATA_FILE=
